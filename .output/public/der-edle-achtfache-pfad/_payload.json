[{"data":1,"prerenderedAt":85},["ShallowReactive",2],{"page-\u002Fder-edle-achtfache-pfad":3},{"id":4,"title":5,"body":6,"description":57,"extension":78,"meta":79,"navigation":80,"path":81,"seo":82,"stem":83,"__hash__":84},"content\u002Fder-edle-achtfache-pfad\u002Findex.md","Der edle Achtfache Pfad",{"type":7,"value":8,"toc":74},"minimark",[9,13,18,22,30,36,42,48,54,62,68],[10,11,5],"h1",{"id":12},"der-edle-achtfache-pfad",[14,15,17],"h2",{"id":16},"ariya-mak-mi-ong-bpät","Ariya Mak Mi Ong Bpät",[19,20,21],"p",{},"Dieser Pfad soll zum Ende von Leiden führen.",[23,24,27],"row-text",{"header":25,"extra-text":26},"1 Rechte Ansicht.","Realisieren dass Leid da ist und, dass die Ursache Verlangen, Anhaftung, Hass und Unwissenheit ist — wenn wir die Ursache loslassen sind wir frei. Dabei hilft der edle achtfache Pfad.",[19,28,29],{},"Verständnis der vier edlen Wahrheiten",[23,31,33],{"header":32},"2 Rechte Gesinnung.",[19,34,35],{},"Absicht zu Verzicht, Wohlwollen, Gewaltlosigkeit.",[23,37,39],{"header":38},"3 Rechte Rede.",[19,40,41],{},"Wahrheitvolle, einteiligende, freundliche & nützliche Worte.",[23,43,45],{"header":44},"4 Rechtes Handeln.",[19,46,47],{},"Handlungen ohne Töten, Stehlen oder sexuellem Fehlverhalten.",[23,49,51],{"header":50},"5 Rechter Lebenserwerb.",[19,52,53],{},"Geldverdienen auf eine Art die nicht schadet, und sogar gut für Menschen ist.",[23,55,59],{"header":56,"extra-text":57,"link":58},"6 Rechte Anstrengung.","","\u002Fder-edle-achtfache-pfad\u002Frechte-anstrengung",[19,60,61],{},"Energie — unheilsame Gedanken zu meiden und heilsame zu fördern.",[23,63,65],{"header":64},"7 Rechte Achtsamkeit.",[19,66,67],{},"Klares Bewusstsein von Körper, Geist, Gefühlen & Phänomenen.",[23,69,71],{"header":70},"8 Rechte Sammlung.",[19,72,73],{},"Tiefe meditative Konzentration.",{"title":57,"searchDepth":75,"depth":75,"links":76},2,[77],{"id":16,"depth":75,"text":17},"md",{},true,"\u002Fder-edle-achtfache-pfad",{"title":5,"description":57},"der-edle-achtfache-pfad\u002Findex","lUgVebvEv4woNafGtsnHB47CPQ10H8xM8JT4LzDT9O0",1775244877208]